TELEGRAM_BOT_TOKEN=123456789:replace_with_token_from_botfather
TELEGRAM_WEBHOOK_SECRET=replace_with_random_secret_azAZ09_-_only
CRON_SECRET=replace_with_random_cron_secret
VERCEL_APP_URL=https://your-project.vercel.app

# Empty value means everyone can use the bot.
# Add comma-separated Telegram numeric user IDs to restrict access.
ALLOWED_USER_IDS=111111111,222222222

BOT_TIMEZONE=Asia/Qyzylorda
BOT_UTC_OFFSET=+05:00

# Vercel KV / Upstash Redis REST storage.
# Required for reliable deploy on Vercel.
KV_REST_API_URL=https://your-kv-url.upstash.io
KV_REST_API_TOKEN=your_kv_rest_token
REMINDERS_KEY=otbasy:reminders
SESSIONS_KEY=otbasy:sessions
